# Database (Neon — injected automatically by Vercel in production)
DATABASE_URL=

# Square
# Get these from developer.squareup.com → your app → Sandbox tab
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=                        # server-side API calls
NEXT_PUBLIC_SQUARE_APPLICATION_ID=         # browser — Square Web Payments SDK
NEXT_PUBLIC_SQUARE_LOCATION_ID=            # browser — same value as SQUARE_LOCATION_ID

# Resend (transactional email — waiver PDF delivery)
# Get from resend.com → API Keys
# Sending domain (appointments@beautybyamy.com) must be verified before production
RESEND_API_KEY=

# Cloudinary (image storage — gallery and site images)
# Get from cloudinary.com → Settings → API Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Twilio (SMS waiver reminders)
# A2P 10DLC registration required before production use
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# NextAuth (admin authentication)
# NextAuth v5 beta reads AUTH_SECRET; NEXTAUTH_SECRET kept for compatibility
# Generate both with the same value: run `openssl rand -base64 32`
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin fallback credentials (credentials provider alongside Google OAuth)
# ADMIN_PASSWORD_HASH: generate with `npx bcryptjs <password>`
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=''  # IMPORTANT: wrap in single quotes — dotenv-expand mangles $ signs in bcrypt hashes even inside double quotes

# Vercel cron authentication
# Any random string — set the same value in Vercel environment variables
CRON_SECRET=

# Site URL (used for building absolute URLs in emails/SMS)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
