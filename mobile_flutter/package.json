{
  "name": "mobile-flutter",
  "private": true,
  "scripts": {
    "dev": "flutter run --dart-define=API_BASE_URL=http://10.0.2.2:3000",
    "build:android": "flutter build apk --dart-define=API_BASE_URL=https://api.example.com",
