# Example environment configuration for BeautyByAmy mobile app
# Copy this to .env and fill in your values

# Stripe publishable key for payment processing (optional for frontend prototype)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# Backend API base URL (optional - using mock API for prototype)
API_BASE_URL=http://localhost:3000

# Owner/admin email for admin login
OWNER_EMAIL=admin@beautybyamy.com

# Owner phone number for notifications
OWNER_PHONE=+1234567890

# Default notification preference for owner
DEFAULT_OWNER_NOTIFY=email
